# Supabase PostgreSQL database URL
# Format: postgresql://postgres.[username]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require
# If using a local or different Postgres instance, adjust accordingly.
DATABASE_URL=postgresql://postgres:your-db-password@localhost:5432/postgres

# Groq API Key (for Llama 3.1 inference)
GROQ_API_KEY=gsk_your_groq_api_key_here

# Gemini API Key (for Google text-embedding-004)
GEMINI_API_KEY=your_gemini_api_key_here

# API Configuration
HOST=0.0.0.0
PORT=8000
